  doc,
)

#verse[
  Já snad #c[G]hned, když jsem se #c[D]narodil, na #c[G]bludnej #c[D]kámen #c[G]šláp'\
  a #c[G]do školy moc #c[D]nechodil, i #c[Emi]tak je #c[D]ze mě #c[Emi]chlap.\
  Velký #ca[G]dusno, který #ca[D]nad hlavou mi #ca[G]doma #ca[D]vise#ca[G]lo,\
  drs#ca[G]nýmu chlapu #ca[D]nesvědčí, já #ca[Emi]ťuk' si #ca[D]na če#ca[Emi]lo.
]

#prechorus[
  #c[Emi]Ho, #s[D]ho, #c[G]ho, #c[D]ho, #c[G]ho, #c[C]ho, #c[G]hou.
]

#chorus[
  Má#c[G]ma mě doma držela a #c[D]táta na mě dřel,\
  já #c[D]moh' jsem jít hned študovat, kdy#c[G]bych jen #c[D]trochu #c[G]chtěl,\
  #c[G]voženit se, vzít si ňákou #c[D]trajdu copatou\
  #c[D]a za její lásku platit #c[G]celou vejplatou, #c[D]jó #c[Emi]hou.
]

#verse[
  Potom #ca[G]do knajpy jsem #ca[D]zašel a tam #ca[G]usly#ca[D]šel ten #ca[G]žvást,\
  že #ca[G]na lodích je #ca[D]veselo a #ca[Emi]fasu#ca[D]jou tam #ca[Emi]chlast.\
  A tak #ca[G]honem jsem se #ca[D]nalodil na #ca[G]starej #ca[D]vetchej #ca[G]křáp,\
  kde #ca[G]kapitán byl #ca[D]kořala a #ca[Emi]řval na #ca[D]nás jak #ca[Emi]dráb.
]

#prechorus[
  Ho, ho, ho, ho...
]

#chorus[
  Máma mě doma držela a táta na mě dřel...
]

#verse[
  Vlny #ca[G]s kocábkou si #ca[D]házely a #ca[G]každej #ca[D]dostal #ca[G]strach\
  a my #ca[G]lodníci se #ca[D]vsázeli, kdo #ca[Emi]přeži#ca[D]je ten #ca[Emi]krach.\
  Všechny #ca[G]krysy z lodi #ca[D]zmizely a #ca[G]v dálce #ca[D]maják #ca[G]zhas'\
  a #ca[G]první byl hned #ca[D]kapitán, kdo #ca[Emi]měl kor#ca[D]kovej #ca[Emi]pás.
]

#prechorus[
  Ho, ho, ho, ho...
]

#chorus[
  Máma mě doma držela a táta na mě dřel...
]

#verse[
  Kolem #ca[G]zubama už #ca[D]cvakali žra#ca[G]loci #ca[D]hlado#ca[G]ví,\
  moc #ca[G]nikomu se #ca[D]nechtělo do #ca[Emi]vody #ca[D]ledo#ca[Emi]vý.\
  K ránu #ca[G]bouře trochu #ca[D]ustala, já #ca[G]mořskou #ca[D]nemoc #ca[G]měl,\
  všem, co #ca[G]můžou chodit #ca[D]po souši, jsem #ca[Emi]tolik #ca[D]závi#ca[Emi]děl.
]

#prechorus[
  Ho, ho, ho, ho...
]

#chorus[
  Máma mě doma držela a táta na mě dřel...
]

#verse[
  Jako #ca[G]zázrakem jsme #ca[D]dojeli, byl #ca[G]každý #ca[D]živ a #ca[G]zdráv\
  a #ca[G]všichni byli #ca[D]veselí, jen #ca[Emi]já jsem #ca[D]rukou #ca[Emi]máv'.\
  Na loď #ca[G]nikdy víc už #ca[D]nevlezu, to #ca[G]nesmí #ca[D]nikdo #ca[G]chtít,\
  teď #ca[G]lituju a #ca[D]vzpomínám, jak #ca[Emi]jen jsem #ca[D]se moh' #ca[Emi]mít.
]

#prechorus[
  Ho, ho, ho, ho...
]

#chorus[
  Máma mě doma držela a táta na mě dřel...
]

