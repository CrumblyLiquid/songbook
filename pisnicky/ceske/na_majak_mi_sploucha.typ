#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Na maják mi šplouchá],
  author: [Skippy's Band],
  doc,
)

#verse[
  #c[Dmi]Venku začalo lejt, #c[C]to je na pytel,\
  #c[G]nemůžu se opalovat, né, né, né.\
  #c[Dmi]Nechal jsi mě bejt, #c[C]to je teda pech,\
  #c[G]zrovna když mám nový plavky.
]

#verse[
  #ca[Dmi]Bílý, dvoudílný, #ca[C]leží ve skříni,\
  #ca[G]nebudu je vytahovat, né, né, né.\
  #ca[Dmi]Fakt, že jsi se zdejch, #ca[C]přijmu ve starejch,\
  #ca[G]sluší a děsně škrtí.
]

#chorus[
  #c[Dmi]Čím, #c[C]víc, #c[G]liják do zdí bouchá,\
  #c[Dmi]tím, #s[C]víc, #c[G]na maják mi šplouchá.
]

#verse[
  #ca[Dmi]Nechal jsi mě bejt, #ca[C]to je teda pech,\
  #ca[G]nebudu si čistit zuby, né, né, né.\
  #ca[Dmi]Kašlu na Colgate, #ca[C]na psí počasí,\
  #ca[G]já do lesa nepojedu.
]

#verse[
  #ca[Dmi]Jsi tam na chatě, #ca[C]nezajímaj tě,\
  #ca[G]bílý zuby ani plavky, né, né, né.\
  #ca[Dmi]Nechal jsi mě bejt, #ca[C]nebudu se mejt,\
  #ca[G]dneska větrám a furt prší.
]

#chorus[
  Čím, víc, liják do zdí bouchá...
]
