#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Proužek],
  author: [Jan a František Nedvědi],
  doc,
)

#verse[
  Ten #d[E]mír, když #c[H7]za kopcem #c[A]sví#c[E]tá,\
  když #d[A]vystřídá se s #c[H7]nocí #c[E]den,\
  a #d[E]proužek dýmu z #c[H7]dřeva slunce #c[A]ví#c[E]tá,\
  z #d[A]kytky motýl #c[H7]vylít' #c[E]ven.
]

#chorus[
  #d[E]Někdo škrtne sirkou, někdo #c[A]zpí#c[E]vá,\
  #d[A]někdo ještě zkouší #c[E]spát,\
  u #d[E]potoka #c[H7]do vody se #c[A]dí#c[E]vá\
  #d[A]jedna holka, #c[H7]co mám #c[E]rád.
]

#verse[
  Vlasy sváže do uzlu a kouká,\
  pak vodu dlaní rozčeří,\
  stud jí sluší, tak jako všem holkám,\
  co na svou krásu nevěří.
]

#chorus[
  Někdo škrtne sirkou...
]

#solo[
  E H7 A E A H7 E H7 A E A H7 E
]

#chorus[
  Někdo škrtne sirkou
]

#verse[
  Z odpadlýho kousku starý kůry\
  srdce jsem jí udělal\
  a večer, když už začly lítat můry,\
  tajně jí ho do spacáku dal.
]

#chorus[
  Někdo škrtne sirkou...\
  [: jedna holka, co mám rád :]
]

