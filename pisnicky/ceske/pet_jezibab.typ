  #ca[F]letí, letí #ca[C]v letu sva#ca[F]čí\
  #ca[Dmi]pět ježibab #ca[A]na tryská#ca[Dmi]či.
]

#verse[
  #ca[Dmi]Pět ježibab #ca[A]s jedním no#ca[Dmi]sem\
