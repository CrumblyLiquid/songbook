#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Kdyby se v komnatách],
  author: [Zdeněk Svěrák a Jaroslav Uhlíř],
  doc,
)

// TODO: Transponovat od C
#verse[
  #d[G]K životu na zámku #c[Dmi]mám jednu poznámku \
  #d[C]Je tu neveselo, je tu #c[G]truchlivo \
  #d[G]V ostatních královstvích #c[Dmi]nezní tak málo smích \
  #d[C]Není neveselo, není #c[G]truchlivo
]

#chorus[
  #d[G7]Kdyby se v #c[C]komnatách běhoun jak #c[Hmi]hrom natáh \
  A na něm #d[Ami]akrobati #c[D]začali #c[G]kejklovati \
  #d[G7]Kdyby nám #c[C]v paláci pištěli #c[Hmi]dudáci \
  To by se #d[Ami]krásně žilo, #c[D]to by byl #c[G]ráj
]

#verse[
  Kde není muzika, tam duše naříká \
  Tam je neveselo, tam je truchlivo \
  Chtěla bych dvůr pestrý, kde znějí orchestry \
  Kde není neveselo, žádné truchlivo
]

#chorus[
  Kdyby se v komnatách...
]


