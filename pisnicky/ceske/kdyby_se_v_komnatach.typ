#verse[
  #c[G]K životu na zámku #c[Dmi]mám jednu poznámku \
  #c[C]Je tu neveselo, je tu #c[G]truchlivo \
  #c[G]V ostatních královstvích #c[Dmi]nezní tak málo smích \
