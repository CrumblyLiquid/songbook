#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Síla starejch vín],
  author: [Škwor],
  capo: 1,
  doc,
)

#verse[
  #c[Emi]Podle nepsanejch #c[C]zákonů, hledáme #c[D]něco, co nám nejspíš schází.\
  #c[Emi]Podle prastarejch #c[C]pudů, který nás #c[D]nutěj, furt za něčím jít.\
  #c[Emi]Do stejný řeky nikdy #c[C]nevstoupíš, klacky #c[D]sám sobě pod nohy házíš.\
  #c[Emi]Cos chtěl máš, stejně #c[C]dojdeš k pozná#c[D]ní.
]

#chorus[
  Že věci #c[G]některý, jsou #c[D]neměnný, jak #c[Emi]síla starejch #c[C]vín.\
  A někdy je #c[Emi]tma, kolem #c[C]nás to když #c[Emi]zrovna nejsme #c[D]stálí.\
  Najednou #c[G]blízký jsou si #c[D]vzdálený to z #c[Emi]očí kouká #c[C]nám.\
  Tak na chvílí #c[Emi]stůj, vzpomí#c[C]nej,\
  no a #c[Emi]přiznej, taky jsme se #c[D]báli, co bude #c[G]dál.
]

#verse[
  #ca[Emi]Každej ctí asi #ca[C]jinej zákon a kdo #ca[D]ví, co nám odvahu dává.\
  #ca[Emi]Každej má asi #ca[C]jinej kód a ty #ca[D]sám zřejmě všechno víš líp.\
  #ca[Emi]Jak když přesadíš #ca[C]starej strom, taky to #ca[D]nebude velká sláva.\
  #ca[Emi]Cos chtěl máš, stejně #ca[C]dojdeš k pozná#ca[D]ní.
]

#chorus[
  Že věci některý, jsou neměnný...
]

