#verse[
  #c[D]Jedu domů po trati, jedu přes kop#c[G A]ce.\
  #c[D]Za okny padá, padá sníh, budou Váno#c[G A]ce.\
  #c[D]Chmury, trable, starosti, nechal jsem ve mě#c[G A]stě.\
  #c[D]Už slyším lidi na půlnoční zpívat v koste#c[G A]le.
]

#bridge[
  Hale#c[D]luja, Hale#c[Hmi]lu-u-u-u-u-#c[G]ja
]

#verse[
  #ca[D]Ježíš na kříži ztrápený, občas se usmě#ca[G A]je.\
  #ca[D]Na ty co v zázrak uvěří, na ty co zpíva#ca[G A]jí.
]

#bridge[
  #rep[Haleluja, Halelu-u-u-u-u-ja]
]

#chorus[
  Beránku #c[D A]náš na nebe#c[Hmi G]sích\
  Stůj při #c[D A]nás, až přijde #c[C2]tma
]

#bridge[
  Haleluja, Halelu-u-u-u-u-ja
]

#verse[
  #ca[D]Stojím v prázdném kostele, hvězdy nade #ca[G A]mnou.\
  #ca[D]Z kříže zbyl jenom stín, ale přesto sly#ca[G A]ším.
]

#bridge[
  #rep[Haleluja, Halelu-u-u-u-u-ja]
]

#chorus[
  Beránku #ca[D A]náš na nebe#ca[Hmi G]sích,\
  stůj při #ca[D A]nás, až přijde #ca[C2]tma.\
  Beránku #ca[D A]náš na nebe#ca[Hmi G]sích,\
  neopouštěj #ca[D A]nás, až začnem se #ca[C2]bá-á-át, bá-á-át.
]

#bridge[
  Haleluja, Halelu-u-u-u-u-ja\
  Haleluja, Halelu-u-u-u-u-ja.\
  Haleluja, Halelu-u-u-u-u-ja,\
