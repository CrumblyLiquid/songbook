#verse[
  Žralok #c[Gmaj7]zuby má jak #c[Ami7]nože\
  a z těch #c[D9]zubů čiší #c[Gmaj7]strach.\
  Mackie #c[Emi]Messer, #c[Bdim]ach můj #c[Ami7]bože,\
  kdo do#c[D9]káže, že je #c[Gmaj7]vrah.
]

#verse[
  Na ná#ca[Gmaj7]břeží řeky #ca[Ami7]Temže\
  leckdo #ca[D9]život doko#ca[Gmaj7]nal.\
  Mor tam #ca[Emi]nebyl, #ca[Bdim]víme #ca[Ami7]jen, že\
  Mackie #ca[D9]Messer blízko #ca[Gmaj7]stál.
]

#verse[
  Jednou #ca[Gmaj7]zmizel chudák #ca[Ami7]Majer,\
  jindy #ca[D9]boháč Müller #ca[Gmaj7]zas.\
  Mackie #ca[Emi]s hůlkou, #ca[Bdim]jako #ca[Ami7]frajer,\
  obchá#ca[D9]zel tam v onen #ca[Gmaj7]čas.
]

#verse[
  Pěkná #ca[Gmaj7]hůlka na pro#ca[Ami7]cházku\
  a v té #ca[D9]hůlce nůž je #ca[Gmaj7]skryt.\
  Mackie #ca[Emi]Messer #ca[Bdim]vyhrál #ca[Ami7]sázku,\
  nic mu #ca[D9]nelze dosvěd#ca[Gmaj7]čit.
]

#verse[
  Jednou #ca[Gmaj7]změnil požár v #ca[Ami7]Soho\
  půlnoc #ca[D9]temnou v denní #ca[Gmaj7]jas.\
  Podez#ca[Emi]řelých #ca[Bdim]bylo #ca[Ami7]mnoho,\
  ale #ca[D9]Mackie zmizel #ca[Gmaj7]včas.
]

#verse[
  Jindy #ca[Gmaj7]zase mladá #ca[Ami7]žena\
  nic ne#ca[D9]tuší a jde #ca[Gmaj7]spát.\
  Probu#ca[Emi]dí se #ca[Bdim]zneuc#ca[Ami7]těna,\
  Mackie #ca[D9]ji však nechce #ca[Gmaj7]znát.
]

#verse[
  Žralok #ca[Gmaj7]zuby má jak #ca[Ami7]nože\
