#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Princezna ze Mlejna],
  author: [Radek Valenta],
  font_size: 0.95em,
  doc,
)

#grid(
  columns: 2,
  row-gutter: 2em,
  column-gutter: 1em,
  verse[
    #d[D]Vím jedno návrší zámek #c[A7]nádher#c[D]nej\
    z nejhez#d[D]čích pohádek ho #c[G]znám.\
    [: Stavě#d[G]nej z křišťá#c[Emi]lu sahá k #c[D]nebi pomálu\
    pově#d[D]tří přijde k #c[A7]duhu prince#c[D]znám :]
  ],

  verse[
    #d[~]Bílé je lilium bílej krásnej sen\
    #d[~]bílé je pravé hedvábí.\
    #d[~]\[: Jdu cestou necestou za svou bílou nevěstou\
    #d[~]jiná mě na tom světě nevábí :\]
  ],

  verse[
    Šípková růžičko z dávnejch příběhů\
    odkvítáš tiše v ústraní.\
    [: Odpusť mi svatej Ján, že tvou krásu nehledám\
    na jinou myslím večer před spaním :]
  ],

  verse[
    Stříbrná tůňka se zhlíží ve hvězdách\
    Velký vůz ztratil zákolník\
    [: Rozsypal nad náma celou fůru s hvězdama\
    jenom já nemám štěstí za troník :]
  ],

  verse[
    Já vím, že v tej noci plnej zázraků\
    vykvet' můj kvítek z poupěte.\
    [: Pomoz mi svatej Ján ať tu chvíli nezmeškám\
    než planě nazdařbůh odkvete :]
  ],

  verse[
    Vím jeden bílej mlejn, zámek stříbrnej,\
    v údolí znám to návrší.\
    [: V tom pěkným stavění je moje potěšení,\
    že na něj myslím, zatím netuší :]
  ],

  verse[
    Bílý je pápěří bílej dobrej den,\
    bílej je ubrus sváteční.\
    [:  Ten kterýho já chci, nosí bílou čepici,\
    ostatní ženiši jsou zbyteční :]
  ],

  verse[
    Vím jedno oudolí, vím já pěknej mlejn,\
    už všechny kořeny v něm znám.\
    [: Bydlí tam panenka, voči má jak pomněnka,\
    jinou už na tom světě nehledám :]
  ],

  verse[
    Vím jedno oudolí, vím já pěknej mlejn,\
    míří sem cesta s přívozem.\
    [: Jde cesta - necesta, tady je má nevěsta,\
    nerovná se jí žádná z princezen :]
  ],

  verse[
    Vím jedno údolí, vím ja pěknej mlejn,\
    vedle něj rybník s rákosím.\
    [: Ta dívčí, co já znám, je má bílá princezna,\
    tu si já vod pantáty vyprosím :]
  ],
)
