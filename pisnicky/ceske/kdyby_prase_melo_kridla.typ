#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Kdyby prase mělo křídla],
  author: [Pavel Šrut],
  doc,
)

#verse[
  #d[F]Kdyby prase mělo křídla,
  #c[F]křídla jako #c[C7]pták,\
  vyle#d[C7]těl bych na praseti někam #c[F]do #c[Db7]o#c[C7]blak.\
  Uvi#d[F]děl bych Itálii,
  #c[F]uvi#c[E]děl #c[Eb]bych #c[D7]svět,\
  #d[B]v Rakousku bych slyšel zvonce,
  #c[F]z výšky koukal #c[D7]na Japonce\
  #d[G7]a pak bych se zase vrátil,
  #c[C7]vrátil bych se #c[F]zpět.
]

#verse[
  Uviděl bys řeku Ganges
  uviděl bys Nil,\
  uviděl bys Madagaskar,
  chvíli bys tam byl,\
  kdyby prase zachrochtalo
  a vzlétlo do oblak,\
  měl bys všude plno přátel
  byl bys slavný cestovatel\
  kdyby prase mělo křídla,
  křídla jako pták.
]

