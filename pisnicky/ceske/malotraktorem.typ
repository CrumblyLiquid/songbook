#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Malotraktorem],
  author: [Mig 21],
  url: "https://www.youtube.com/watch?v=5XiVx5m7mcQ",
  doc,
)

#verse[
  #rep[
    #c[D]Cestou necestou, polem ne polem,\
    #c[G]jedu za Tebou, #c[Gmi]velkým malotrakto#c[D]rem
  ]\
  #c[D]kabrioletem.#c[G B]
]

#verse[
  #rep[
    #ca[D]Pojď mi naproti, lesem ne lesem,\
    #ca[G]pojď si mě vyfotit, #ca[Gmi]jak tam na traktoru #ca[D]jsem
  ]\
  #ca[D]jak jsem roztřesen.#ca[G B]
]

#bridge[
  #rep[
    #c[D]Vrn vrn drndrn drndrn
  ]\
  #c[G]Drn drn drn drn drn drn
]

#chorus[
  #rep[
    #c[D]Jen kola zdolaj výmoly, pálím to lesem po poli,\
    #c[G]lán pole mizí pod koly, #c[B]z kopce to ale vosolím.
  ]
]

#verse[
  #rep[
    #ca[D]Cestou necestou, polem ne polem,\
    #ca[G]jedu za Tebou, #ca[Gmi]létem kabriole#ca[D]tem
  ]\
  #ca[D]malotraktorem.#ca[G B]
]

#bridge[
  Vrn vrn drndrn drndrn...
]

#chorus[
  Jen kola zdolaj výmoly...
]

#verse[
  #c[D]Doufám, že mě pochopíš,\
  že mě usly#c[Emi7]šíš, že mě potěšíš, #c[Gmi]mít budeš #c[D]ráda.\
  #c[D]Doufám, že mě pocho#c[Gmi]píš a budeš #c[D]mít #c[G]ráda #c[Gmi]\
  #rep(repeat: 3)[
    a budeš #c[D]mít #c[G]ráda #c[Gmi][~]
  ]#c[D]
]

