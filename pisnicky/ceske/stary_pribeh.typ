#import "@local/crumblysong:0.1.0": *;

#import "/style.typ": style;
#show: style

#show: doc => song(
  title: [Starý příběh],
  author: [Spirituál kvintet],
  doc,
)

#verse[
  Řek' #c[D]Mojžíš jednou lidu svému "přišel čas,\
  dnes v noci tiše #c[F\#mi]vytratí se #c[G]každý #c[A7]z vás."\
  #c[D]Má#c[D7]vá, #c[G]mává nám #c[D]všem svo#c[A7]bodná #c[D]zem.
]

#verse[
  Já #ca[D]říkám rovnou "každý ať s tím počítá,\
  že naše cesta #ca[F\#mi]ke štěstí je #ca[G]trni#ca[A7]tá."\
  #ca[D]Má#ca[D7]vá, #ca[G]mává nám #ca[D]všem svo#ca[A7]bodná #ca[D]zem.
]

#chorus[
  A #c[D]kdo se bojí vodou jít,\
  ten podle tónů faraónů musí #c[A7]žít.\
  #c[D]Má#c[D7]vá, #c[G]mává nám #c[D]všem svo#c[A7]bodná #c[D]zem.
]

#verse[
  Až #ca[D]první krůček bude jednou za námi,\
  tak nikdo nesmí #ca[F\#mi]zaváhat, dát #ca[G]na fá#ca[A7]my.\
  #ca[D]Má#ca[D7]vá, #ca[G]mává nám #ca[D]všem svo#ca[A7]bodná #ca[D]zem.
]

#verse[
  Pak #ca[D]tenhle vandr všem potomkům ukáže,\
  že šanci má jen #ca[F\#mi]ten, kdo má dost #ca[G]kurá#ca[A7]že.\
  #ca[D]Má#ca[D7]vá, #ca[G]mává nám #ca[D]všem svo#ca[A7]bodná #ca[D]zem.
]

#chorus[
  Kdo se bojí vodou jít...
]

#verse[
  Ten #ca[D]starý příběh z knížky vám tu vykládám,\
  ať každý ví, že #ca[F\#mi]rozhodnout se #ca[G]musí #ca[A7]sám...\
  #ca[D]Má#ca[D7]vá, #ca[G]mává nám #ca[D]všem svo#ca[A7]bodná #ca[D]zem.
]

#chorus[
  Kdo se bojí vodou jít...
]
