#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Včelín],
  author: [Čechomor],
  doc,
)

#verse[
  \[: #c[Ami]Sousedovic Věra #c[G]má #c[Ami]jako žádná #c[G]jiná,\
  #c[Ami]Viděl jsem ji včera #c[G]máchat #c[Ami]dole #c[Emi]u vče#c[Ami]lína. :\]
]

#chorus[
  \[: #c[Ami]Dóle dole dole dole, #c[C]dole dole dóle,\
  #c[G]hej dole dole dole, dole u vče#c[Ami]lína. :\]
]

#verse[
  \[: Líčka jako růže máš, já tě musím dostat.\
  Nic ti nepomůže spát - skočím třeba do sna. :\]
]

#chorus[
  Dóle dole dole...
]

#verse[
  \[: Ať v poledne radost má, slunko hezky hřeje,\
  když se na mě podívá, dám jí co si přeje :\]
]

#chorus[
  Dóle dole dole...
]

#verse[
  \[: Líčka jako růže máš, zajdu k panu králi,\
  ať přikázat vašim dá, aby mi tě dali :\]
]

#chorus[
  Dóle dole dole...
  Dóle dole dole...
  Hej, hej, hej!
]
