#verse[
  #c[Ami]Prázdej byt je jako #c[F]past, kde #c[Dmi]růže uvad#c[C]no#c[G]u,\
  #c[Ami]potisící #c[F]čtu tvůj dopis #c[Dmi]na rozlouče#c[G]nou,\
  #c[C]píšeš, že #c[Ami]odcházíš, když #c[Dmi]den se s nocí #c[C]stří#c[G]dá,\
  #c[Ami]vodu z vína #c[F]udělá, kdo #c[Dmi]dobře nehlí#c[G Gsus4 G]dá.
]

#chorus[
  Píšeš:\
  #c[C]Proklí#c[G]nám, #c[Ami]ty tvoje #c[F]ústa proklí#c[C]nám,\
  tvoje #c[G]oči ledo#c[Ami]vý, #s[F]v srdci jen sníh,\
  #c[C]sám a #c[G]sám, #c[Ami]ať nikdy #c[F]úsvit nespat#c[C]říš,\
  na ústa #c[G]mříž, oči oslep#c[Ami]nou, ať #c[F]do smrti seš #c[C]sám.
]

#verse[
  #ca[Ami]Tvoje oči #ca[F]jsou jak stín a #ca[Dmi]tvář den, když se #ca[C]stmí#ca[G]vá,\
  #ca[Ami]stromy rostou #ca[F]čím dál výš a #ca[Dmi]pak je čeká #ca[G]pád,\
  #ca[C]sám s hlavou #ca[Ami]skloněnou, všechny #ca[F]lásky budou #ca[C]zdá#ca[G]ní,\
  #ca[Ami]potisící #ca[F]čtu tvůj dopis #ca[Dmi]na rozlouče#ca[G Gsus4 G]nou.
]

#chorus[
  Píšeš: Proklínám...
]

