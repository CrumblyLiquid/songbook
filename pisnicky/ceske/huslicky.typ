#verse[
  \[: #c[C]Čí že ste, husličky, #c[F]či#w[C][e,]~\
  #c[Dmi]kdo vás tu #c[Ami]zane#w[G]chal :\]\
  #c[Dmi7]na trávě #c[G]pová#w[C]lané,#c[F][~]~\
  #c[Dmi]na trávě #c[G]pová#w[C]lané,#c[F][~]~\
  #c[Dmi]u paty #c[Ami]oře#w[G]cha?#c[Dmi Ami G]
]

#verse[
  \[: A kdože tu trávu tak zválal,\
  aj modré fialy, :\]\
  \[: že ste, husličky, samé :\]\
  na světě zostaly?
]

#verse[
  \[: A který tu muzikant usnul\
  a co sa mu přišlo zdát, :\]\
  \[: co sa mu enem zdálo, bože :\]\
  že už vjec nechtěl hrát?
]

#verse[
  \[: Zahrajte, husličky, samy,\
  zahrajte zvesela, :\]\
  \[: až sa tá bude trápit, :\]\
  která ho nechtěla.
]

