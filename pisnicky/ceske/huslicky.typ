#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Husličky],
  author: [Hradišťan],
  doc,
)

#verse[
  #rep[
    #d[C]Čí že ste, husličky, #c[F]či#w[C]e,\
    #d[Dmi]kdo vás tu #c[Ami]zane#w[G]chal
  ]\
  #d[Dmi7]na trávě #c[G]pová#w[C]lané,#c[F]\
  #d[Dmi]na trávě #c[G]pová#w[C]lané,#c[F]\
  #d[Dmi]u paty #c[Ami]oře#w[G]cha?#c[Dmi Ami G]
]

#verse[
  #rep[
    A kdože tu trávu tak zválal,\
    aj modré fialy,
  ]\
  #rep[že ste, husličky, samé]\
  na světě zostaly?
]

#verse[
  #rep[
    A který tu muzikant usnul\
    a co sa mu přišlo zdát,
  ]\
  #rep[co sa mu enem zdálo, bože]\
  že už vjec nechtěl hrát?
]

#verse[
  #rep[
    Zahrajte, husličky, samy,\
    zahrajte zvesela,
  ]\
  #rep[až sa tá bude trápit,]\
  která ho nechtěla.
]

