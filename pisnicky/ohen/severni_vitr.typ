#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Severní vítr],
  author: [Jaroslav Uhlíř],
  doc,
)

#verse[
  Jdu #d[C]s děravou patou, mám #c[Ami]horečku zlatou,\
  jsem #d[F]chudý, jsem sláb, nemo#c[C]cen\
  #d[C]hlava mně pálí a #c[Ami]v modravé dáli\
  se #d[F]leskne a #c[G7]třpytí můj #c[C]sen.
]
#verse[
  Kraj pod sněhem mlčí, tam stopy jsou vlčí,\
  tam zbytečně budeš mi psát,\
  sám v dřevěné boudě sen o zlaté hroudě\
  já nechám si tisíckrát zdát.
]
#chorus[
  #d[C]Severní #c[C7]vítr je #c[F]krutý,\
  #d[C]počítej, lásko má, #c[G7]s tím,\
  #d[C]k nohám ti #c[C7]dám zlaté #c[F]pruty,\
  #d[F]nebo se #c[C]vůbec #c[G7]nevrá#c[C]tím.
]
#verse[
  Tak zarůstám vousem a vlci už jdou sem,\
  už slyším je výt blíž a blíž,\
  už mají mou stopu, už větří, že kopu\
  svůj hrob a že stloukám si kříž.
]
#verse[
  Zde leží ten blázen, chtěl dům a chtěl bazén\
  a opustil tvou krásnou tvář,\
  má plechovej hrnek, v něm pár zlatej zrnek\
  a nad hrobem polární zář.
]
#chorus[
  Severní vítr je krutý...
]

