#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Já budu chodit po špičkách],
  author: [Petr Novák],
  doc,
)

#verse[
  #c[D]Zavři oči #c[G]a jdi spát, #c[Emi]vždyť už bude #c[A]brzo den,\
  #c[D]nech si o mně #c[G]něco zdát, #c[Emi]ať je krásný #c[A]ten tvůj sen.
]

#chorus[
  #c[Emi]Já budu chodit #c[A]po špičkách, #c[Emi]snad tě tím nevzbu#c[A]dím,\
  #c[Emi]ááá, až slunce #c[A]vyjde v tmách, #c[G]polibkem tě #c[A]probudím.
]

#verse[
  #ca[D]Jdi si lehnout, #ca[G]ať už spíš, #ca[Emi]ať z toho snu #ca[A]něco máš,\
  #ca[D]ráno, až se #ca[G]probudíš, #ca[Emi]polibek mi #ca[A]taky dáš.
]

#chorus[
  Já budu chodit...
]

#verse[
  #ca[D]Rozhoď vlasy #ca[G]na polštář #ca[Emi]a sni o mně #ca[A]krásnej sen,\
  #ca[D]nebo ráno #ca[G]nepoznáš, #ca[Emi]že je tady #ca[A]nový den.
]

#chorus[
  Já budu chodit...
]

