#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Lízátko],
  author: [Ivan Mládek],
  doc,
)

#verse[
  #d[D]Lízát#c[H7]ko, #c[E7]já našel #c[A7]na zemi #c[D]lízát#c[Dmaj7][ko,]~\
  #d[Hmi]Fdimněkdo ho #c[Fdim]olízal #c[Emi]drobát#c[H7][ko]~\
  #d[Emi]a já se #c[A7]na něj nezlo#c[D\#dim]bím\
  (já #d[D]nejsem #c[D\#dim]žádná#c[Emi]fajnov#c[A7]ka).
]

#verse[
  To #d[D]lízát#c[H7]ko, #c[E7]lízal #c[A7]kluk, či malé #c[D]robát#c[Dmaj7][ko,]~\
  #d[Hmi]případné #c[Fdim]bacily #c[Emi]v tom suchu a zimě\
  #d[E7]uhynuly zakrát#c[A7]ko\
  (do#d[B7]bře jim #c[A7]tak).
]

#verse[
  Nejlepší #d[D]cukrátko je totiž #c[Ami7]lízátko,\
  #d[D]starého chlapa #c[D7]zanese do doby,\
  #d[G]kdy byl ještě #c[H7]malé holátko\
  (#d[Emi]mám dneska, #c[A7]z pekla štěstí).
]

#verse[
  #d[D]Lízát#c[H7]ko, #c[E7]já #c[A7]našel na zemi #c[D]lízát#c[Dmaj7][ko,]~\
  #d[Hmi]pán za mnou #c[Fdim]má mě za #c[Emi]prasát#c[H7][ko]~\
  #d[Emi]a já se #c[A7]na něj nezlo#c[D]bím.#c[G D]
]

