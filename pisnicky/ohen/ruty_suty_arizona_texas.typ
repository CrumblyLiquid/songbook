#verse[
  #d[G]Šinu si to starým Kolorádem,\
  #d[G]když tu slyším výkřik vzdále#c[D7]ný\
  #d[G]jel sem podle #c[G7]hlasu #c[C]a k mému #c[Cmi]úžasu\
  #d[G]ležel tam muž #c[D7]v krvi skole#c[G]ný.
]
#chorus[
  #d[G]Ruty šuty Arizóna, Texas\
  #d[G]Ruty šuty Arizóna #c[D7]má.\
  #d[G]jel sem podle #c[G7]hlasu #c[C]a k mému #c[Cmi]úžasu\
  #d[G]ležel tam muž #c[D7]v krvi skole#c[G]ný.
]
#verse[
  Obracím ho k sobě obličejem,\
  poznal sem v něm svého dvojníka,\
  jeho tělo bylo probodáno nožem,\
  teplá krev mu z rány vytéká.
]
#chorus[
  Ruty šuty Arizóna...
]
#verse[
  Pravil ke mně hlasem zmírajícím,\
  Johny příteli můj jediný\
  byla to léčka, já to nevěděl\
  jako starej vůl sem naletěl.
]
#chorus[
  Ruty šuty Arizóna...
]

