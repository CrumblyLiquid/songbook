#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Rovnou, tady rovnou],
  author: [Michal Tučný],
  doc,
)

#verse[
  #d[D]Tak už jsem ti teda #c[D7]fouk',\
  #d[G]prsten si dej za klo#c[D]bouk,\
  #d[G]nechci tě znát a #c[D]neměl jsem tě rád,\
  #d[D]to ti ří#c[A7]kám rov#c[D]nou.
]

#chorus[
  Rovnou, jó, tady rovnou,\
  rovnou, jó, tady rovnou,\
  prostě těpic a nehledej mě víc,\
  to ti říkám rovnou.
]

#verse[
  Z Kentucky do Tennesee\
  přes hory a přes lesy,\
  z potoků vodou já smejval stopu svou,\
  to ti říkám rovnou.
]

#chorus[
  Rovnou, jó, tady rovnou...
]

