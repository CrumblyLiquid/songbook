]
#verse[
  [: Ač bylo kyselé, přecaj sem sa opil, :]\
  [: eště včil sa stydím, eště včil sa stydím,\
  co sem všecko tropil. :]
]
#verse[
  [: Ale sa něhněvám, žes' mňa ošidila, :]\
  [: to ta moja žízeň, to ta moja žízeň,\
  ta to zavinila. :]
]

