#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Divoké koně],
  author: [Jaromír Nohavica],
  url: "https://www.youtube.com/watch?v=HNR63itf1mc",
  doc,
)

#verse[
  #rep[
    #c[Ami]Já viděl #c[Dmi]divoké #c[Ami]koně, #c[C]běželi #c[Dmi]soumra#c[Ami]kem,
  ]\
  #c[Dmi]vzduch #c[Ami]těžký #c[Dmi]byl a divně #c[Ami]voněl #c[Ddim]tabá#w[F]kem,\
  #c[Dmi]vzduch #c[Ami]těžký #c[Dmi]byl a divně #c[Ami]voněl #c[E7]tabá#c[Ami]kem.
]

#verse[
  #rep[
    #ca[Ami]Běželi, běželi #ca[Dmi]bez uzdy a #ca[Ami]sedla
    #ca[C]krajinou #ca[Dmi]řek a #ca[Ami]hor,
  ]\
  #rep[
    #ca[Dmi]sper to #ca[Ami]čert, jaká #ca[Dmi]touha je to #ca[Ami]vedla
    #ca[Ddim / E7]za ob#ca[F / Ami]zor?
  ]
]

#verse[
  #rep[
    #ca[Ami]Snad vesmír #ca[Dmi]nad ves#ca[Ami]mírem,
    #ca[C]snad lístek #ca[Dmi]na věč#ca[Ami]nost,
  ]\
  #rep[
    #ca[Dmi]naše #ca[Ami]touho, #ca[Dmi]ještě neu#ca[Ami]mírej,
    #ca[Ddim / E7]sil máme #ca[F / Ami]dost.
  ]
]

#verse[
  #rep[
    #ca[Ami]V nozdrách sládne #ca[Dmi]zápach #ca[Ami]klisen
    #ca[C]na břehu #ca[Dmi]jeze#ca[Ami]ra,
  ]\
  #rep[
    #ca[Dmi]milo#ca[Ami]vání je #ca[Dmi]divoká #ca[Ami]píseň
    #ca[Ddim / E7]veče#ca[F / Ami]ra.
  ]
]

#verse[
  #rep[
    #ca[Ami]Stébla trávy #ca[Dmi]sklání #ca[Ami]hlavu,
    #ca[C]staví se #ca[Dmi]do ši#ca[Ami]ku,
  ]\
  #rep[
    #ca[Dmi]král s #ca[Ami]dvořany #ca[Dmi]přijíždí na #ca[Ami]popravu
    #ca[Ddim / E7]zbojní#ca[F / Ami]ků.
  ]
]

#verse[
  #rep[
    #ca[Ami]Chtěl bych jak divoký #ca[Dmi]kůň běžet,
    #ca[Ami]běžet, #ca[C]nemyslet #ca[Dmi]na náv#ca[Ami]rat,
  ]\
  #rep[
    #ca[Dmi]s koňskými #ca[Ami]handlíři #ca[Dmi]vyrazit #ca[Ami]dveře,
    #ca[Ddim / E7]to bych #ca[F / Ami]rád.
  ]
]

#verse(numbered: false, suffix: [])[
  Já viděl divoké koně! (_A capella_)
]
