#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Divoké koně],
  author: [Jaromír Nohavica],
  doc,
)

#verse[
  [: #d[Ami]Já viděl #c[Dmi]divoké #c[Ami]koně, #c[C]běželi #c[Dmi]soumra#c[Ami]kem, :]\
  #d[Dmi]vzduch #c[Ami]těžký #c[Dmi]byl a divně #c[Ami]voněl #c[Ddim][tabá]~#w[F][kem,]~\
  #d[Dmi]vzduch #c[Ami]těžký #c[Dmi]byl a divně #c[Ami]voněl #c[E7]tabá#c[Ami]kem.
]

#verse[
  [: Běželi, běželi bez uzdy a sedla krajinou řek a hor, :]\
  [: sper to čert, jaká touha je to vedla za obzor? :]
]

#verse[
  [: Snad vesmír nad vesmírem, snad lístek na věčnost, :]\
  [: naše touho, ještě neumírej, sil máme dost. :]
]

#verse[
  [: V nozdrách sládne zápach klisen na břehu jezera, :]\
  [: milování je divoká píseň večera. :]
]

#verse[
  [: Stébla trávy sklání hlavu, staví se do šiku, :]\
  [: král s dvořany přijíždí na popravu zbojníků. :]
]

#verse[
  [: Chtěl bych jak divoký kůň běžet, běžet, nemyslet na návrat, :]\
  [: s koňskými handlíři vyrazit dveře, to bych rád. :]\
  Já viděl divoké koně...
]

