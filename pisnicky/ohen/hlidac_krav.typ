#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Hlídač krav],
  author: [Jaromír Nohavica],
  doc,
)

// TODO: Uvozovky\
#verse[
  #c[D]Když jsem byl malý, říkali mi naši:\
  "Dobře se uč a jez chytrou kaši,\
  #c[G]až jednou vyrosteš, #c[A]budeš doktorem #c[D]práv,\
  #c[D]takový doktor sedí pěkně v suchu,\
  bere velký peníze a škrábe se v uchu,"\
  #c[G]já jim ale na to řek: "#c[A]Chci být hlídačem #c[D]krav."
]

#chorus[
  Já chci #c[D]mít čapku s bambulí nahoře,\
  jíst kaštany, mýt se v lavoře,\
  #c[G]od rána po celý #c[A]den zpívat si #c[D]jen,\
  zpívat si: #c[D]pam pam pam padadadadam...#c[G A D]
]

#verse[
  #ca[D]K Vánocům mi kupovali hromady knih,\
  co jsem ale vědět chtěl, to nevyčet' jsem z nich:\
  #ca[G]nikde jsem se nedozvě#ca[A]děl, jak se hlídají #ca[D]krávy,\
  #ca[D]ptal jsem se starších a ptal jsem se všech,\
  každý na mě hleděl jako na pytel blech,\
  #ca[G]každý se mě opatrně #ca[A]tázal na moje #ca[D]zdraví.
]

#chorus[
  Já chci mít čapku...
]

#verse[
  #ca[D]Dnes už jsem starší a vím, co vím,\
  mnohé věci nemůžu a mnohé smím,\
  #ca[G]a když je mi velmi smut#ca[A]no, lehnu si do mokré #ca[D]trávy,\
  #ca[D]s nohama křížem a s rukama za hlavou\
  koukám nahoru na oblohu modravou,\
  #ca[G]kde se mezi mraky ho#ca[A]ní moje strakaté #ca[D]krávy.
]

#chorus[
  Já chci mít čapku...
]

