#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Jednou mi fotr povída],
  author: [Jan Kalousek],
  doc,
)

#verse[
  #c[A7]Jednou mi fotr povídá, #c[D7]zůstali jsme už sami dva,\
  že #c[E7]si chce začít taky trochu #c[A7][žít,]~\
  #c[A7]nech si to projít palicí #c[D7]a nevracej se s vopicí,\
  snaž #c[E7]se mě hochu trochu pocho#c[A7]pit.
]

#chorus[
  Já #c[E7]šel, šel dál, baby, #c[A7]kam mě Pánbůh zval,\
  já #c[E7]šel, šel dál, baby, a #c[D7]furt jen tancoval,\
  #c[A7]na každý divný hranici, #c[D7]na policejní stanici\
  #c[E7]hrál jsem jenom rock'n'roll for #c[A7]you.
]

#verse[
  #ca[A7]Přiletěl se mnou černej čáp, #ca[D7]zobákem dělal klapy klap\
  a #ca[E7]nad kolíbkou Elvis Presley #ca[A7]stál,\
  #ca[A7]obrovskej bourák v ulici, #ca[D7]po boku krásnou slepici\
  a #ca[E7]lidi šeptaj: přijel ňákej #ca[A7]král.
]

#chorus[
  Já šel, šel dál, baby, kam mě Pánbůh zval, ...
]

#verse[
  #ca[A7]Pořád tak ňák nemohu, #ca[D7]chytit štěstí za nohu\
  a #ca[E7]nemůžu si najít klidnej #ca[A7]kout,\
  #ca[A7]bláznivý ptáci začnou řvát #ca[D7]a nový ráno šacovat\
  a #ca[E7]do mě pustí vždycky silnej #ca[A7]proud.
]

#chorus[
  Já šel, šel dál, baby, kam mě Pánbůh zval, ...
]

