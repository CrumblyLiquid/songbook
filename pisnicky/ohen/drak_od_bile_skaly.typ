#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Drak od Bílé skály],
  author: [Rangers - Plavci],
  doc,
)

// TODO: Uvozovky
#chorus[
  #d[G]Drak od bílé #c[Hmi]skály byl #c[C]kdysi moří #c[G]král,\
  však #d[C]posledních pár #c[G]stole#c[Emi]tí ten #c[A7]drak by si jen #c[D7]hrál,\
  #d[G]drak od bílé #c[Hmi]skály #c[C]je jen dvouhla#c[G]vý,\
  však #d[C]hry zná všechny, #c[G]co jich #c[Emi]je,
  neb #d[A7]víc hlav #c[D7]více #c[G]ví.
]

#verse[
  #d[G]Tam k té bílé #c[Hmi]skále #c[C]jednou zbloudil #c[G]kluk,\
  #d[C]v očích pět let #c[G]údi#c[Emi]vu a #c[A7]v rukou vůni #c[D7]luk,\
  #d[G]od té doby #c[Hmi]stále si #c[C]chodil s drakem #c[G]hrát,\
  no#d[C]sil mu hračky #c[G]s klička#c[Emi]mi a #c[A7]měl ho hrozně #c[D7]rád,\
  když #d[G]pluli spolu #c[Hmi]v mořích, #c[C]na stráži kluk #c[G]stál,\
  #d[C]lodě vlajky #c[G]skláně#c[Emi]ly, když #c[A7]drak jim #c[D7]pozdrav #c[G]dal.
]

#chorus[
  Drak od bílé skály...
]

#verse[
  Drak ten žije stále, ale chlapci stárnou dál,\
  hračky, šavle, sítě, míč ustoupí jiným hrám,\
  léta běží dále, kluk už nechodí si hrát,\
  na cestách pak drakovi chybí kamarád.\
  Až půjdeš k bílé skále, kde drak čeká léta už,\
  řekni: "Draku, pojď si hrát", ať kluk jsi, i když muž.
]

#chorus[
  Drak od bílé skály...
]

