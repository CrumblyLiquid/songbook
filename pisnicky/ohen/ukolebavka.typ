#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Ukolébavka],
  author: [Jaromír Nohavica],
  doc,
)

#verse[
  #d[G]Den už se seše#c[G/F]řil, #c[Emi7]už jste si dost u#c[D/F\#]ži#w[G][li,]~\
  tak #d[Ami]hajdy do pe#c[C/G]řin, a #c[D7/F\#]ne, abyste tam moc řá#c[Ami/G]di#w[D7/A][li,]~\
  #d[G]zítra je taky #c[G/F]den, #c[Emi7]slunko mi to dneska slí#c[D/F\#]bi#w[G][lo,]~\
  #d[Ami7]přejme si hezký #c[C/G]sen, a #c[D7/F\#]kéž by se nám to spl#c[Ami/G]ni#w[D7/A][lo,]~\
  #d[G Emi Hmi Emi][na na na...] aby hůř #c[Ami]nebylo, to by nám #c[D7]stačilo.
]
#chorus[
  #d[G]Hajduly, #c[C]dajdu#c[G]ly, aby víčka #c[D]sklapnu#c[G]ly,\
  #d[G]hajduly #c[C]daj#c[G]dy, každý svou peřinu #c[D]naj#c[G]di,\
  #d[G]hajajajajaja#c[D]ja#c[G]ja, Kuba, Lenka, máma #c[D]a #c[G]já,\
  #d[G]zítra, dřív než slunce #c[C]začne #c[G]hřát,\
  #d[G]dobrou noc #c[D]a #c[G]spát.
]
#verse[
  V noci někdy chodí strach, srdce náhle dělá buch-buchy,\
  nebojte, já spím na dosah, když mě zavoláte, zbiju zlé duchy,\
  zítra je taky den, slunko mi to dneska slíbilo,\
  přejme si hezký sen, a kéž by se nám to splnilo,\
  na na na..., aby hůř nebylo, to by nám stačilo.
]
#chorus[
  Hajduly, dajduly...
]

