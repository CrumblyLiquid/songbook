#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Morituri te salutant],
  author: [Karel Kryl],
  doc,
)

#verse[
  Cesta je #d[Ami]prach a #c[G]štěrk a #c[Dmi]udusaná #c[Ami]hlína\
  #d[C]a šedé #c[F]šmouhy #c[G7]kreslí do vla#c[C]sů\
  [: a z hvězdných #d[Dmi]drah má #c[G]šperk, co #c[C]kamením #c[E]sepíná\
  #d[Ami]a pírka #c[G]touhy #c[Emi]z křídel Pega#c[Ami]sů. :]
]

#verse[
  Cesta je bič, je zlá jak pouliční dáma,\
  má v ruce štítky, v pase staniol,\
  [: a z očí chtíč jí plá, když háže do neznáma\
  dvě křehké snítky rudých gladiol. :]
]

#chorus[
  Seržante, #d[G]písek je bílý jak paže Daniely,\
  #d[Ami]počkejte chvíli! Mé oči uviděly\
  #d[G]tu strašně dávnou vteřinu zapomnění,\
  #d[Ami]seržante! Mávnou, #c[G7]a budem zasvěceni!\
  #d[Ami]Morituri te salutant, #c[E]morituri te salutant!
]

#verse[
  Tou cestou dál jsem šel, kde na zemi se zmítá\
  a písek víří křídlo holubí,\
  [: a marš mi hrál zvuk děl, co uklidnění skýtá\
  a zvedá chmýří, které zahubí. :]
]

#verse[
  Cesta je tér a prach a udusaná hlína,\
  mosazná včelka od vlkodlaka,\
  [: rezavý kvér - můj brach a sto let stará špína\
  a děsně velká bílá oblaka. :]
]

#chorus[
  Seržante, písek je bílý...
]

