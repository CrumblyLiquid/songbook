#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Alenka v Říši divů (2014)],
  doc,
)

#verse[
  #d[D]Jednoho dne malá #c[G]holčička,\
  #d[A]potkala bílého #c[D]králíčka,\
  #d[D]za ním běžela, #c[G]však nevěděla,\
  #d[A]do Říše divů #c[D]sletěla.
]

#verse[
  Houseňák, Šklíba i květinka,\
  Kloboučník a taky Alenka,\
  i obě královny věděly,\
  že se schyluje k boji.
]

#chorus[
  #d[D]My je přeci ne#c[G]zradíme,\
  #d[A]Říši osvo#c[D]bodíme,\
  #d[D]Vorpálový meč #c[G]vezmem žádná řeč,\
  #d[A]Tlachapouda #c[D]skolíme.
]

#verse[
  Stačí nám k tomu odvaha,\
  statečnost a taky rozvaha,\
  každý ať mozek namáhá,\
  úsměv ten vždycky pomáhá.
]

#verse[
  Orákulum přeci předvídá,\
  že zlo Nádherňajs vystřídá,\
  bude veselo proto pak,\
  zatančíme si Futrovák.
]

#chorus[
  My je přeci nezradíme...
]

