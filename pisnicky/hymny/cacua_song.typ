#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [ČaČua song (2011)],
  doc,
)

#grid(
  columns: 2,
  row-gutter: 2em,
  verse[
    #d[G]Ráno vstanu, hledám #c[Emi]kalhoty,\
    v tom zase #d[C]vedoucí počítá #c[D]do pěti,\
    a tak se #d[G]vyhrabu ze svojí #c[Emi]postele,\
    to nám ten #d[C]nový den začíná #c[D]vesele.
  ],
  chorus[
    #d[D]Je tady #c[G]fajn, #c[A]fajn,\
    #d[C]vždyť nejsem tu #c[G]sám,\
    #d[D]ČaČuu #c[G]znám, #c[A]znám,\
    #d[C]plno přátel tu #c[G]mám.
  ],
)

#set par(spacing: 1em)

#verse[
  Po ránu poctivě cvičíme,\
  rukama, nohama i hlavou kroutíme,\
  pak vezmem kartáčky a taky plecháčky,\
  snad budou k snídani zas nějaký koláčky.
]

#chorus[
  Je tady fajn, fajn...
]

#verse[
  Vedoucí pak třikrát zapíská,\
  a všechny lenochy ze stanu vylíská,\
  a tak se doplazím ze stanu k oddílu,\
  zas nějaká etapa – se z toho pominu.
]

#chorus[
  Je tady fajn, fajn...
]

#verse[
  Pevné boty, pití, pláštěnku,\
  pak všechny mrňata, dostanem obálku,\
  luštíme, běháme, běháme, luštíme,\
  v nohách pár kiláků, snad se neztratíme.
]

#chorus[
  Je tady fajn, fajn...
]

#verse[
  Po obědě dáme leháro,\
  musíme zdrbat to, co se zas událo,\
  pak dáme fotbálek a nebo vybiku,\
  je večer, stmívá se, tak půjdem k ohýnku.
]

#chorus[
  Je tady fajn, fajn...
]

#verse[
  U ohně zpíváme s kytárou,\
  vždyť další perný den už máme za sebou,\
  vlezem do spacáků a každý usíná,\
  vždyť zítra nový den nám zase začíná.
]

#chorus[
  Je tady fajn, fajn...
]

