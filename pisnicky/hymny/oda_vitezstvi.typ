#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Óda vítězství (2012)],
  doc,
)

#verse[
  #d[C]Plachty vzhůru, #c[F]vyplouváme,\
  #d[C]cíl už máme #c[G]v dohledu,\
  #d[C]my se nikdy #c[F]nenecháme,\
  #d[C]hledíme vždy #c[G]ku #c[C]předu.
]

#chorus[
  #d[G]Afrika, #c[C]Asie, #c[G]Ame#c[C]rika,\
  #d[G]nako#c[C]nec zas #c[F]Evro#c[G]pa,\
  #d[C]všude dobře #c[F]doma nejlíp,\
  #d[C]to je pravda #c[G]odvě#c[C]ká.
]

#verse[
  Žádný stesk a žádný smutek,\
  hrdinně pluj dál a dál,\
  nešvindluj a nepodváděj,\
  jen tak se dá jíti dál.
]

#chorus[
  Afrika, Asie, Amerika...
]

#verse[
  14 dní je před námi,\
  a cesta značně strnitá,\
  obletíme celý svět,\
  a pak zpátky do Londýna.
]

#chorus[
  Afrika, Asie, Amerika...
]

