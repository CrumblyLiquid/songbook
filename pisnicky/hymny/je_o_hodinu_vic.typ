#import "@local/crumblysong:0.1.0": *;

#show: doc => song(
  title: [Je o hodinu víc (2021)],
  doc,
)

#verse[
  #d[Ami]Ráno svítá nad manéží Petěrburgu,\
  #d[F]šelmy #c[E]ještě #c[Ami]spí.\
  #d[Ami]Do Ruska třeba přidat na hodinkách\
  #d[F]o ho#c[E]dinu #c[Ami]víc.
]
// TODO: Zkontrolovat pozice akordů\
#chorus[
  V#d[C] zákulisí #c[Dmi]nervózní #c[E]akrobati\
  #d[F]přemety cvi#c[H7]čí, proto#c[E]že čas se krátí.\
  #d[Ami]Do Ruska třeba přidat na hodinkách\
  #d[F]o ho#c[E]dinu #c[Ami]víc.
]

#verse[
  Nad zemřelým Humbertem stále tiše\
  truchlí šašků král.\
  Uslzený přetáčí minut ruku\
  o kolečko dál.
]

#chorus[
  Jeho žalu nic není rovno přímo,\
  Vy jste tím vinen, Vy Giuseppe Panino.\
  Vy jste tím vinen, cirkus ke dnu klesá,\
  čert aby to spral.
]

#chorus[
  Jeho žalu nic není rovno přímo,\
  Vy jste tím vinen, Vy Giuseppe Panino.\
  Vyšlo slunce nad střechy Petěrburgu,\
  je o hodinu víc.
]

